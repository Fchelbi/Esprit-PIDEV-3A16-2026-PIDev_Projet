<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: DejaVu Sans, Arial, sans-serif;
        font-size: 11px;
        color: #1a2332;
        background: #fff;
        padding: 0;
    }

    /* ── COVER HEADER ── */
    .cover {
        background: linear-gradient(135deg, #0d1321 0%, #1a2d4a 100%);
        color: #fff;
        padding: 40px 50px 30px;
        margin-bottom: 0;
    }

    .cover-logo {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: -0.5px;
        margin-bottom: 6px;
    }

    .cover-logo span { color: #E8895A; }

    .cover-subtitle {
        font-size: 13px;
        color: rgba(255,255,255,0.55);
        margin-bottom: 20px;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .cover-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        border-left: 4px solid #E8895A;
        padding-left: 14px;
        margin-bottom: 8px;
    }

    .cover-date {
        font-size: 11px;
        color: rgba(255,255,255,0.5);
        padding-left: 18px;
    }

    /* ── BODY CONTENT ── */
    .body { padding: 30px 50px; }

    /* ── SECTION TITLES ── */
    .section-title {
        font-size: 13px;
        font-weight: 700;
        color: #0d1321;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-bottom: 2px solid #E8895A;
        padding-bottom: 6px;
        margin: 28px 0 14px;
    }

    .section-title:first-child { margin-top: 0; }

    /* ── KPI GRID ── */
    .kpi-grid {
        width: 100%;
        border-collapse: separate;
        border-spacing: 8px;
        margin-bottom: 6px;
    }

    .kpi-cell {
        width: 25%;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 14px 12px;
        text-align: center;
        vertical-align: middle;
    }

    .kpi-cell.accent { border-top: 3px solid #E8895A; }
    .kpi-cell.blue   { border-top: 3px solid #3b82f6; }
    .kpi-cell.green  { border-top: 3px solid #22c55e; }
    .kpi-cell.red    { border-top: 3px solid #ef4444; }
    .kpi-cell.purple { border-top: 3px solid #a855f7; }
    .kpi-cell.teal   { border-top: 3px solid #14b8a6; }

    .kpi-value {
        font-size: 26px;
        font-weight: 700;
        color: #0d1321;
        display: block;
        margin-bottom: 4px;
    }

    .kpi-label {
        font-size: 9.5px;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        font-weight: 600;
    }

    /* ── DATA TABLE ── */
    .data-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 10px;
        font-size: 10.5px;
    }

    .data-table thead tr {
        background: #0d1321;
        color: #fff;
    }

    .data-table thead th {
        padding: 9px 12px;
        text-align: left;
        font-weight: 600;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .data-table tbody tr:nth-child(even) { background: #f8fafc; }
    .data-table tbody tr:nth-child(odd)  { background: #fff; }

    .data-table tbody td {
        padding: 8px 12px;
        border-bottom: 1px solid #e2e8f0;
        vertical-align: middle;
    }

    .badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .badge-admin   { background: rgba(232,137,90,0.15); color: #c2612a; }
    .badge-coach   { background: rgba(59,130,246,0.12); color: #1d4ed8; }
    .badge-patient { background: rgba(34,197,94,0.12);  color: #15803d; }
    .badge-banned  { background: rgba(239,68,68,0.12);  color: #b91c1c; }
    .badge-active  { background: rgba(34,197,94,0.12);  color: #15803d; }

    /* ── BIEN-ETRE BARS ── */
    .bewell-row {
        margin-bottom: 10px;
    }

    .bewell-label {
        font-size: 10px;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        margin-bottom: 4px;
    }

    .bar-track {
        background: #e2e8f0;
        border-radius: 4px;
        height: 12px;
        width: 100%;
        position: relative;
    }

    .bar-fill {
        height: 12px;
        border-radius: 4px;
        display: inline-block;
    }

    .bar-value {
        font-size: 10px;
        font-weight: 700;
        color: #0d1321;
        margin-left: 6px;
    }

    /* ── FOOTER ── */
    .footer {
        background: #f8fafc;
        border-top: 2px solid #e2e8f0;
        padding: 16px 50px;
        margin-top: 20px;
        font-size: 9.5px;
        color: #94a3b8;
        text-align: center;
    }

    .footer strong { color: #E8895A; }

    /* ── PAGE BREAK ── */
    .page-break { page-break-before: always; }

    /* ── TWO-COL LAYOUT ── */
    .two-col { width: 100%; border-collapse: collapse; }
    .two-col td { width: 50%; vertical-align: top; padding-right: 12px; }
    .two-col td:last-child { padding-right: 0; padding-left: 12px; }
</style>
</head>
<body>

<!-- ════════════ HEADER ════════════ -->
<div class="cover">
    <div class="cover-logo">Echo<span>Care</span></div>
    <div class="cover-subtitle">Mental Health Community Platform</div>
    <div class="cover-title">Admin Statistics Report</div>
    <div class="cover-date">Generated on {{ date|date('F j, Y') }} at {{ date|date('H:i') }}</div>
</div>

<div class="body">

    <!-- ════════════ USER STATISTICS ════════════ -->
    <div class="section-title">User Statistics</div>
    <table class="kpi-grid">
        <tr>
            <td class="kpi-cell accent">
                <span class="kpi-value">{{ totalUsers }}</span>
                <span class="kpi-label">Total Users</span>
            </td>
            <td class="kpi-cell blue">
                <span class="kpi-value">{{ totalAdmins }}</span>
                <span class="kpi-label">Administrators</span>
            </td>
            <td class="kpi-cell green">
                <span class="kpi-value">{{ totalCoachs }}</span>
                <span class="kpi-label">Coaches</span>
            </td>
            <td class="kpi-cell purple">
                <span class="kpi-value">{{ totalPatients }}</span>
                <span class="kpi-label">Patients</span>
            </td>
        </tr>
    </table>
    <table class="kpi-grid">
        <tr>
            <td class="kpi-cell red">
                <span class="kpi-value">{{ bannedUsers }}</span>
                <span class="kpi-label">Banned Users</span>
            </td>
            <td class="kpi-cell teal">
                <span class="kpi-value">{{ activeForumUsers }}</span>
                <span class="kpi-label">Active Forum Users</span>
            </td>
            <td style="width:50%;"></td>
        </tr>
    </table>

    <!-- ════════════ FORUM STATISTICS ════════════ -->
    <div class="section-title">Forum Statistics</div>
    <table class="kpi-grid">
        <tr>
            <td class="kpi-cell accent">
                <span class="kpi-value">{{ totalPosts }}</span>
                <span class="kpi-label">Total Posts</span>
            </td>
            <td class="kpi-cell red">
                <span class="kpi-value">{{ flaggedPosts }}</span>
                <span class="kpi-label">Flagged Posts</span>
            </td>
            <td class="kpi-cell blue">
                <span class="kpi-value">{{ totalComments }}</span>
                <span class="kpi-label">Total Comments</span>
            </td>
            <td class="kpi-cell green">
                <span class="kpi-value">{{ postsByCategory|keys|length }}</span>
                <span class="kpi-label">Categories</span>
            </td>
        </tr>
    </table>

    {% if postsByCategory %}
    <div class="section-title">Posts by Category</div>
    <table class="data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Category</th>
                <th>Post Count</th>
                <th>Share</th>
            </tr>
        </thead>
        <tbody>
            {% for categoryName, count in postsByCategory %}
            <tr>
                <td>{{ loop.index }}</td>
                <td>{{ categoryName }}</td>
                <td><strong>{{ count }}</strong></td>
                <td>
                    {% if totalPosts > 0 %}
                        {{ ((count / totalPosts) * 100)|round(1) }}%
                    {% else %}—{% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}

    <!-- ════════════ BIEN-ETRE AVERAGES ════════════ -->
    {% if avgBienEtre.avgSommeil is not null %}
    <div class="section-title">Well-being Averages (Bien-être)</div>
    <table class="two-col">
        <tr>
            <td>
                <div class="bewell-row">
                    <div class="bewell-label">Sleep Quality (Sommeil)</div>
                    <div class="bar-track">
                        <div class="bar-fill" style="width: {{ ((avgBienEtre.avgSommeil ?? 0) / 10 * 100)|round }}%; background: #3b82f6;"></div>
                    </div>
                    <span class="bar-value">{{ avgBienEtre.avgSommeil ? avgBienEtre.avgSommeil|round(1) : 'N/A' }} / 10</span>
                </div>
                <div class="bewell-row">
                    <div class="bewell-label">Stress Level</div>
                    <div class="bar-track">
                        <div class="bar-fill" style="width: {{ ((avgBienEtre.avgStress ?? 0) / 10 * 100)|round }}%; background: #ef4444;"></div>
                    </div>
                    <span class="bar-value">{{ avgBienEtre.avgStress ? avgBienEtre.avgStress|round(1) : 'N/A' }} / 10</span>
                </div>
                <div class="bewell-row">
                    <div class="bewell-label">Mood (Humeur)</div>
                    <div class="bar-track">
                        <div class="bar-fill" style="width: {{ ((avgBienEtre.avgHumeur ?? 0) / 10 * 100)|round }}%; background: #22c55e;"></div>
                    </div>
                    <span class="bar-value">{{ avgBienEtre.avgHumeur ? avgBienEtre.avgHumeur|round(1) : 'N/A' }} / 10</span>
                </div>
            </td>
            <td>
                <table class="data-table">
                    <thead><tr><th>Metric</th><th>Average</th><th>Scale</th></tr></thead>
                    <tbody>
                        <tr><td>Sleep Quality</td><td><strong>{{ avgBienEtre.avgSommeil ? avgBienEtre.avgSommeil|round(2) : '—' }}</strong></td><td>0–10</td></tr>
                        <tr><td>Stress Level</td><td><strong>{{ avgBienEtre.avgStress ? avgBienEtre.avgStress|round(2) : '—' }}</strong></td><td>0–10</td></tr>
                        <tr><td>Mood Score</td><td><strong>{{ avgBienEtre.avgHumeur ? avgBienEtre.avgHumeur|round(2) : '—' }}</strong></td><td>0–10</td></tr>
                    </tbody>
                </table>
            </td>
        </tr>
    </table>
    {% endif %}

    <!-- ════════════ PAGE 2 — USER LIST ════════════ -->
    <div class="page-break"></div>

    <div class="section-title">Recently Registered Users (Last 10)</div>
    <table class="data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Phone</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            {% for user in recentUsers %}
            <tr>
                <td>{{ loop.index }}</td>
                <td><strong>{{ user.prenom }} {{ user.nom }}</strong></td>
                <td>{{ user.email }}</td>
                <td>
                    <span class="badge badge-{{ user.role|lower }}">{{ user.role }}</span>
                </td>
                <td>{{ user.numTel ?? '—' }}</td>
                <td>
                    {% if user.isBanned %}
                        <span class="badge badge-banned">Banned</span>
                    {% else %}
                        <span class="badge badge-active">Active</span>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="section-title">Complete User Directory ({{ allUsers|length }} users)</div>
    <table class="data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Phone</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            {% for user in allUsers %}
            <tr>
                <td>{{ loop.index }}</td>
                <td>{{ user.prenom }} {{ user.nom }}</td>
                <td style="font-size:9.5px;">{{ user.email }}</td>
                <td><span class="badge badge-{{ user.role|lower }}">{{ user.role }}</span></td>
                <td>{{ user.numTel ?? '—' }}</td>
                <td>
                    {% if user.isBanned %}
                        <span class="badge badge-banned">Banned</span>
                    {% else %}
                        <span class="badge badge-active">Active</span>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

</div>

<!-- ════════════ FOOTER ════════════ -->
<div class="footer">
    <strong>EchoCare</strong> &nbsp;·&nbsp; Admin Statistics Report &nbsp;·&nbsp; {{ date|date('Y-m-d H:i') }} &nbsp;·&nbsp; Confidential — For Internal Use Only
</div>

</body>
</html>
