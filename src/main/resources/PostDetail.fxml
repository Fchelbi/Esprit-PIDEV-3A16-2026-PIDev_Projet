<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.PostDetailController"
      minHeight="720">

    <fx:include source="Sidebar.fxml"/>

    <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;
                       -fx-border-color: transparent;">

        <VBox style="-fx-background-color: #F2F0EC;">

            <!-- ── Header bar ── -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 18 30 18 30;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                <Button text="← Back to Feed" onAction="#onBack"
                        style="-fx-background-color: #EDF2F7; -fx-text-fill: #4A5568;
                               -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                               -fx-background-radius: 8; -fx-padding: 8 14 8 14;
                               -fx-cursor: hand;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="📝" style="-fx-font-size: 22;"/>
            </HBox>

            <!-- ── Centered content area ── -->
            <VBox alignment="TOP_CENTER" spacing="16"
                  style="-fx-padding: 25 30 35 30;">

                <!-- Post card (populated from controller) -->
                <VBox fx:id="postBox" maxWidth="800" spacing="16"
                      style="-fx-background-color: white; -fx-background-radius: 14;
                             -fx-padding: 28;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 2);"/>

                <!-- Comments section -->
                <VBox maxWidth="800" spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="10"
                          style="-fx-padding: 8 0 4 0;">
                        <Label text="💬" style="-fx-font-size: 16;"/>
                        <Label text="Comments"
                               style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #2D3748;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblCommentCount"
                               style="-fx-font-size: 13; -fx-text-fill: #718096;"/>
                    </HBox>
                    <VBox fx:id="commentsBox" spacing="10"/>
                </VBox>

                <!-- Write a reply card -->
                <VBox maxWidth="800" spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 14;
                             -fx-padding: 18;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 1);">
                    <Label text="Write a reply"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #2D3748;"/>
                    <TextArea fx:id="taReply" prefRowCount="3" wrapText="true"
                              style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0;
                                     -fx-border-radius: 8; -fx-background-radius: 8;
                                     -fx-padding: 10 14 10 14;"/>
                    <HBox alignment="CENTER_RIGHT">
                        <Button text="Post Reply" onAction="#onPostReply"
                                style="-fx-background-color: #E8956D; -fx-text-fill: white;
                                       -fx-background-radius: 8; -fx-padding: 9 20 9 20;
                                       -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

            </VBox>
        </VBox>
    </ScrollPane>

</HBox>