<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.PostController"
            styleClass="root-pane">

    <top>
        <VBox styleClass="top-bar">
            <HBox styleClass="title-bar" alignment="CENTER_LEFT" spacing="12">
                <padding>
                    <Insets top="16" right="16" bottom="16" left="16"/>
                </padding>
                <Label text="FORUM POSTS" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Refresh" styleClass="btn-secondary" onAction="#onRefresh"/>
            </HBox>
            <Separator/>
        </VBox>
    </top>

    <center>
        <TableView fx:id="postsTable" styleClass="data-table">
            <columns>
                <TableColumn fx:id="colId"       text="ID"         prefWidth="55"/>
                <TableColumn fx:id="colTitle"    text="TITLE"      prefWidth="200"/>
                <TableColumn fx:id="colCategory" text="CAT ID"     prefWidth="80"/>
                <TableColumn fx:id="colContent"  text="CONTENT"    prefWidth="220"/>
                <TableColumn fx:id="colCreatedAt" text="CREATED AT" prefWidth="160"/>
                <TableColumn fx:id="colStatus"   text="STATUS"     prefWidth="120"/>
                <TableColumn fx:id="colUserId"   text="USER ID"    prefWidth="80"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <VBox styleClass="form-area" spacing="10">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <Label text="ADD / EDIT POST" styleClass="form-title"/>

            <HBox spacing="10">
                <TextField fx:id="titleField"    promptText="Title"                  HBox.hgrow="ALWAYS"/>
                <ComboBox  fx:id="categoryCombo" promptText="Category"               prefWidth="170"/>
                <TextField fx:id="photoField"    promptText="Photo URL (optional)"   prefWidth="220"/>
            </HBox>

            <TextArea fx:id="contentField" promptText="Content..." prefHeight="80" wrapText="true"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Save"             styleClass="btn-primary"   onAction="#onSave"/>
                <Button text="Update Selected"  styleClass="btn-secondary" onAction="#onUpdate"/>
                <Button text="Delete Selected"  styleClass="btn-danger"    onAction="#onDelete"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="View Comments"    styleClass="btn-action"    onAction="#onViewComments"/>
                <Button text="Clear"            styleClass="btn-secondary" onAction="#onClear"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>