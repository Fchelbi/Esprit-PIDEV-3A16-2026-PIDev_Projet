<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.PieChart?>

<HBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.ManagementController"
      minHeight="720">

    <fx:include source="Sidebar.fxml"/>

    <VBox HBox.hgrow="ALWAYS"
          spacing="26"
          style="-fx-background-color: #F2F0EC; -fx-padding: 36;">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox spacing="4">
                <Label text="Forum Admin"
                       style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #3F6094;"/>
                <Label text="Manage forum posts, comments, reactions and statistics."
                       style="-fx-font-size: 14; -fx-text-fill: #F2935E;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Export PDF Report"
                    onAction="#onExportPdf"
                    style="-fx-background-color: #E8956D; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 22 12 22;"/>
        </HBox>

        <!-- Cards row -->
        <HBox spacing="18">

            <VBox spacing="8"
                  style="-fx-background-color: #3F6094; -fx-background-radius: 16; -fx-padding: 24;"
                  prefWidth="230">
                <Label text="TOTAL POSTS"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 12; -fx-font-weight: bold;"/>
                <Label fx:id="lblTotalPosts"
                       text="0"
                       style="-fx-text-fill: #E8956D; -fx-font-size: 32; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="8"
                  style="-fx-background-color: #3F6094; -fx-background-radius: 16; -fx-padding: 24;"
                  prefWidth="230">
                <Label text="TOTAL COMMENTS"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 12; -fx-font-weight: bold;"/>
                <Label fx:id="lblTotalComments"
                       text="0"
                       style="-fx-text-fill: #68D391; -fx-font-size: 32; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="8"
                  style="-fx-background-color: #3F6094; -fx-background-radius: 16; -fx-padding: 24;"
                  prefWidth="230">
                <Label text="ACTIVE USERS"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 12; -fx-font-weight: bold;"/>
                <Label fx:id="lblActiveUsers"
                       text="0"
                       style="-fx-text-fill: #F6E27A; -fx-font-size: 32; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="8"
                  style="-fx-background-color: #3F6094; -fx-background-radius: 16; -fx-padding: 24;"
                  prefWidth="230">
                <Label text="FLAGGED POSTS"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 12; -fx-font-weight: bold;"/>
                <Label fx:id="lblFlaggedPosts"
                       text="0"
                       style="-fx-text-fill: #F6AD55; -fx-font-size: 32; -fx-font-weight: bold;"/>
            </VBox>

        </HBox>

        <!-- Reactions row -->
        <HBox spacing="18">

            <VBox spacing="8"
                  style="-fx-background-color: #3F6094; -fx-background-radius: 16; -fx-padding: 24;"
                  prefWidth="230">
                <Label text="POST LIKES"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 12; -fx-font-weight: bold;"/>
                <Label fx:id="lblPostLikes"
                       text="0"
                       style="-fx-text-fill: #F6E27A; -fx-font-size: 30; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="8"
                  style="-fx-background-color: #3F6094; -fx-background-radius: 16; -fx-padding: 24;"
                  prefWidth="230">
                <Label text="POST DISLIKES"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 12; -fx-font-weight: bold;"/>
                <Label fx:id="lblPostDislikes"
                       text="0"
                       style="-fx-text-fill: #FC8181; -fx-font-size: 30; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="8"
                  style="-fx-background-color: #3F6094; -fx-background-radius: 16; -fx-padding: 24;"
                  prefWidth="230">
                <Label text="COMMENT LIKES"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 12; -fx-font-weight: bold;"/>
                <Label fx:id="lblCommentLikes"
                       text="0"
                       style="-fx-text-fill: #68D391; -fx-font-size: 30; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="8"
                  style="-fx-background-color: #3F6094; -fx-background-radius: 16; -fx-padding: 24;"
                  prefWidth="230">
                <Label text="COMMENT DISLIKES"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 12; -fx-font-weight: bold;"/>
                <Label fx:id="lblCommentDislikes"
                       text="0"
                       style="-fx-text-fill: #FC8181; -fx-font-size: 30; -fx-font-weight: bold;"/>
            </VBox>

        </HBox>
        <!-- Charts row -->
        <HBox spacing="18">

            <VBox spacing="12"
                  style="-fx-background-color: #FFD1B3; -fx-background-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 2);"
                  prefWidth="520">
                <Label text="Posts Activity"
                       style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1A202C;"/>
                <Label text="Posts created during the last 30 days"
                       style="-fx-font-size: 12; -fx-text-fill: #1A202C;"/>

                <LineChart fx:id="postsActivityChart"
                           prefHeight="280"
                           legendVisible="false"
                           animated="false">
                    <xAxis>
                        <CategoryAxis label="Date"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Posts"/>
                    </yAxis>
                </LineChart>
            </VBox>

            <VBox spacing="12"
                  style="-fx-background-color: #FFD1B3; -fx-background-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 2);"
                  prefWidth="420">
                <Label text="Posts by Category"
                       style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1A202C;"/>
                <Label text="Distribution of posts by category"
                       style="-fx-font-size: 12; -fx-text-fill: #1A202C;"/>

                <PieChart fx:id="postsByCategoryChart"
                          prefHeight="280"
                          legendVisible="true"
                          labelsVisible="true"/>
            </VBox>

        </HBox>

    </VBox>

</HBox>